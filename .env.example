# Slack bot / app credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CLIENT_ID=1234567890.1234567890
SLACK_CLIENT_SECRET=your-client-secret
SLACK_REDIRECT_BASE_URL=https://example.ngrok-free.app
SLACK_RUN_MODE=socket
PORT=3000

# Upstage
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxx
UPSTAGE_BASE_URL=https://api.upstage.ai/v2
UPSTAGE_MODEL=solar-mini
UPSTAGE_FALLBACK_MODEL=solar-pro2
UPSTAGE_TIMEOUT_SECONDS=30
UPSTAGE_MAX_RETRIES=1

# Storage / scheduling
STORE_ENCRYPTION_KEY=replace-with-fernet-key
STORE_PATH=./data/store.enc
CAPABILITY_LOG_PATH=./artifacts/mcp-capability-spike.json
DIGEST_POLL_SECONDS=60
DEFAULT_TIMEZONE=UTC
LOG_LEVEL=INFO
