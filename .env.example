# Runtime
APP_ENV=development
LOG_LEVEL=INFO
PORT=3000
APP_BASE_URL=http://localhost:3000
DEFAULT_TIMEZONE=Asia/Seoul

# Slack app / bot
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_STATE_SECRET=

# Slack MCP
SLACK_MCP_BASE_URL=https://mcp.slack.com/mcp
SLACK_MCP_CLIENT_ID=
SLACK_MCP_CLIENT_SECRET=
SLACK_MCP_REDIRECT_URI=http://localhost:3000/auth/slack-mcp/callback
SLACK_MCP_SCOPES=

# Upstage
UPSTAGE_API_KEY=
UPSTAGE_BASE_URL=https://api.upstage.ai/v2
# Replace with the Solar chat model enabled in your Upstage account.
UPSTAGE_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1

# Delivery / summarization
SUMMARY_VISIBLE_CHAR_BUDGET=900
DIGEST_POLL_INTERVAL_SECONDS=60
DEFAULT_DIGEST_TIME=18:00
DEFAULT_DIGEST_CHANNEL=app_home

# Persistence / crypto
DATA_DIR=./data
SQLITE_PATH=./data/slack_assistant.db
ENCRYPTION_KEY=
SESSION_COOKIE_SECRET=

# Observability
ENABLE_JSON_LOGS=true
REDACT_LOG_FIELDS=authorization,cookie,set-cookie,token,access_token,refresh_token
